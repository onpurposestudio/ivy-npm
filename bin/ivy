#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

RUSTFLAGS="-A warnings" cargo build --manifest-path "$REPO_ROOT/packages/ivy/Cargo.toml" --quiet

IVY_TOKEN="beta" "$REPO_ROOT/packages/ivy/target/debug/ivy" "$@"
